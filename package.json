{
  "name": "gestconv360",
  "version": "0.1.0",
  "private": true,
  "description": "API do modulo Instrumentos/Propostas do Gestconv360",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check:quality": "npm run build && npm run web:build && npm run test:tickets-regression",
    "start": "node dist/server.js",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "seed:demo": "tsx src/scripts/seed-demo-instrumentos.ts",
    "test:tickets-regression": "tsx src/scripts/tickets-regression-check.ts",
    "dev:restart": "tsx src/scripts/run-and-restart-dev-servers.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "googleapis": "^144.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.13.13",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
