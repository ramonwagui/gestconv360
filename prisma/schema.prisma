generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum InstrumentStatus {
  EM_ELABORACAO
  ASSINADO
  EM_EXECUCAO
  VENCIDO
  PRESTACAO_PENDENTE
  CONCLUIDO
}

enum UserRole {
  ADMIN
  GESTOR
  CONSULTA
}

enum AuditAction {
  CREATE
  UPDATE
  DEACTIVATE
}

model User {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CONSULTA)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  auditLogs    AuditLog[]
}

model InstrumentProposal {
  id                    Int              @id @default(autoincrement())
  proposta              String           @unique
  instrumento           String           @unique
  objeto                String
  valorRepasse          Decimal
  valorContrapartida    Decimal
  dataCadastro          DateTime
  dataAssinatura        DateTime?
  vigenciaInicio        DateTime
  vigenciaFim           DateTime
  dataPrestacaoContas   DateTime?
  dataDou               DateTime?
  concedente            String
  status                InstrumentStatus @default(EM_ELABORACAO)
  responsavel           String?
  orgaoExecutor         String?
  observacoes           String?
  conveneteId           Int?
  convenete             Convenete?       @relation(fields: [conveneteId], references: [id])
  ativo                 Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  auditLogs             AuditLog[]
  checklistItems        InstrumentChecklistItem[]

  @@index([concedente])
  @@index([status])
  @@index([ativo])
  @@index([vigenciaFim])
  @@index([conveneteId])
}

model InstrumentChecklistItem {
  id                 Int      @id @default(autoincrement())
  instrumentId       Int
  nomeDocumento      String
  obrigatorio        Boolean  @default(true)
  concluido          Boolean  @default(false)
  observacao         String?
  ordem              Int      @default(0)
  arquivoPath        String?
  arquivoNomeOriginal String?
  arquivoMimeType    String?
  arquivoTamanho     Int?
  uploadedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  instrument InstrumentProposal @relation(fields: [instrumentId], references: [id], onDelete: Cascade)

  @@index([instrumentId, ordem])
}

model AuditLog {
  id            Int                @id @default(autoincrement())
  instrumentId  Int
  userId        Int?
  userEmail     String
  action        AuditAction
  changedFields Json?
  beforeData    Json?
  afterData     Json?
  createdAt     DateTime           @default(now())

  instrument InstrumentProposal @relation(fields: [instrumentId], references: [id])
  user       User?              @relation(fields: [userId], references: [id])

  @@index([instrumentId])
  @@index([createdAt])
}

model Convenete {
  id        Int      @id @default(autoincrement())
  nome      String
  cnpj      String   @unique
  endereco  String
  bairro    String
  cep       String
  uf        String
  cidade    String
  tel       String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  instrumentos InstrumentProposal[]

  @@index([nome])
  @@index([cidade])
}
